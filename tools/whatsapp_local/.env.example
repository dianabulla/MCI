DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mcimadrid

# Tiempo máximo de conexión a MySQL en ms
DB_CONNECT_TIMEOUT_MS=15000

# SSL para MySQL remoto (Hostinger puede requerirlo según plan)
# disabled | required
DB_SSL_MODE=disabled
# true valida certificado CA; false evita bloqueo por CA en entornos compartidos
DB_SSL_REJECT_UNAUTHORIZED=false

# Opcional: para sesiones separadas por ambiente
WA_CLIENT_ID=mcimadrid_server

# true para servidor (sin UI), false para debug local con navegador visible
WA_HEADLESS=true

# Número de mensajes por lote
WA_BATCH_LIMIT=20

# Pausa entre mensajes en ms
WA_DELAY_MS=3500

# Intervalo de polling de cola en ms
WA_POLL_MS=5000

# Intentos máximos por mensaje antes de marcar fallido
WA_MAX_ATTEMPTS=3
